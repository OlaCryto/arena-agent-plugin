# Avalanche C-Chain RPC URL
RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Server port
PORT=3000

# Admin secret for managing API keys
ADMIN_SECRET=change-me-to-something-secure

# ArenaRouter wrapper contract address (deploy first, then set this)
ARENA_ROUTER=

# Slippage tolerance in basis points (100 = 1%)
SLIPPAGE_BPS=100
