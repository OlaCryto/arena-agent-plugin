{
  "name": "logiqical",
  "version": "0.3.1",
  "description": "Agent wallet SDK for Avalanche — swap, stake, launchpad, DEX, perps, bridge, social, signals. No backend needed.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "logiqical-mcp": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "avalanche",
    "arena",
    "defi",
    "sdk",
    "ai-agent",
    "trading",
    "logiqical",
    "wallet",
    "agent-wallet",
    "signals",
    "perps",
    "bridge",
    "mcp"
  ],
  "license": "MIT",
  "repository": {},
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ethers": "^6.16.0",
    "zod": "^3.24.4"
  }
}
